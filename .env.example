# ===========================================
# FMP Dashboard - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e configure os valores

# -----------------------------------------
# Banco de Dados MySQL (para producao)
# -----------------------------------------
# Host do servidor MySQL
DB_HOST=localhost

# Porta do MySQL (padrao: 3306)
DB_PORT=3306

# Usuario do banco de dados
DB_USER=root

# Senha do banco de dados
DB_PASSWORD=

# Nome do banco de dados
DB_NAME=fmp_dashboard

# String de conexao completa (alternativa as variaveis acima)
# DATABASE_URL=mysql://user:password@host:port/database

# -----------------------------------------
# n8n Webhook Integration
# -----------------------------------------
# Chave de API para autenticacao do webhook n8n
# Use uma chave forte e unica (ex: openssl rand -hex 32)
N8N_API_KEY=your-secure-api-key-here

# -----------------------------------------
# Autenticacao JWT
# -----------------------------------------
# Chave secreta para tokens JWT (ex: openssl rand -hex 64)
JWT_SECRET=your-jwt-secret-key-change-in-production

# -----------------------------------------
# Configuracoes da Aplicacao
# -----------------------------------------
# URL base da API (para deploy em producao)
NEXT_PUBLIC_API_URL=https://your-domain.com

# Ambiente (development, production)
NODE_ENV=development
