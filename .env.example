# ===========================================
# FMP Dashboard - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e configure os valores

# -----------------------------------------
# Banco de Dados MySQL
# -----------------------------------------
# Host do servidor MySQL
DB_HOST=localhost

# Porta do MySQL (padrão: 3306)
DB_PORT=3306

# Usuário do banco de dados
DB_USER=root

# Senha do banco de dados
DB_PASSWORD=

# Nome do banco de dados
DB_NAME=fmp_dashboard

# String de conexão completa (alternativa às variáveis acima)
# DATABASE_URL=mysql://user:password@host:port/database

# -----------------------------------------
# n8n Webhook Integration
# -----------------------------------------
# Chave de API para autenticação do webhook n8n
# Use uma chave forte e única
N8N_API_KEY=your-secure-api-key-here

# URL do webhook n8n (opcional, para callbacks)
N8N_WEBHOOK_URL=

# -----------------------------------------
# Configurações de Monitoramento
# -----------------------------------------
# Intervalo de atualização em segundos (padrão: 60)
# UPDATE_INTERVAL=60

# Intervalo de rotação automática em segundos (padrão: 10)
# AUTO_ROTATION_INTERVAL=10

# -----------------------------------------
# Configurações da Aplicação
# -----------------------------------------
# URL base da API (para deploy em produção)
# NEXT_PUBLIC_API_URL=https://your-domain.com

# Ambiente (development, production)
NODE_ENV=development
